      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=HeThongBanTayVang;Trusted_Connection=true;TrustServerCertificate=true;"
  },

