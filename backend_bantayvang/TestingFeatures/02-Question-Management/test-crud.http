@baseUrl = https://localhost:7293

### Test Question CRUD Operations

### 1. GET All Questions (with pagination)
GET {{baseUrl}}/api/cauhoi?PageNumber=1&PageSize=5
Accept: application/json

### 2. GET Question by ID
GET {{baseUrl}}/api/cauhoi/1
Accept: application/json

### 3. CREATE New Question - Success Case
POST {{baseUrl}}/api/cauhoi
Content-Type: application/json

{
  "idDanhMuc": 1,
  "idLoaiCauHoi": 1,
  "noiDung": "Test Question: Phương thức nào được sử dụng để in ra console trong C#?",
  "diem": 1.0,
  "doKho": "Dễ",
  "khoaPhong": "CNTT",
  "danhSachLuaChon": [
    {
      "noiDung": "Console.WriteLine()",
      "laDapAnDung": true,
      "thuTu": 1
    },
    {
      "noiDung": "System.out.println()",
      "laDapAnDung": false,
      "thuTu": 2
    },
    {
      "noiDung": "print()",
      "laDapAnDung": false,
      "thuTu": 3
    },
    {
      "noiDung": "cout <<",
      "laDapAnDung": false,
      "thuTu": 4
    }
  ]
}

### 4. CREATE Question - Validation Error (No correct answer)
POST {{baseUrl}}/api/cauhoi
Content-Type: application/json

{
  "idDanhMuc": 1,
  "idLoaiCauHoi": 1,
  "noiDung": "Test Question: Invalid question with no correct answer",
  "diem": 1.0,
  "doKho": "Dễ",
  "khoaPhong": "CNTT",
  "danhSachLuaChon": [
    {
      "noiDung": "Wrong Answer 1",
      "laDapAnDung": false,
      "thuTu": 1
    },
    {
      "noiDung": "Wrong Answer 2",
      "laDapAnDung": false,
      "thuTu": 2
    }
  ]
}

### 5. UPDATE Question - Success Case (use ID from create response)
PUT {{baseUrl}}/api/cauhoi/8
Content-Type: application/json

{
  "id": 8,
  "idDanhMuc": 1,
  "idLoaiCauHoi": 1,
  "noiDung": "Updated Question: Phương thức nào được sử dụng để in ra console trong C#? (Updated)",
  "diem": 1.5,
  "doKho": "Trung bình",
  "khoaPhong": "CNTT",
  "danhSachLuaChon": [
    {
      "noiDung": "Console.WriteLine()",
      "laDapAnDung": true,
      "thuTu": 1
    },
    {
      "noiDung": "Console.Write()",
      "laDapAnDung": false,
      "thuTu": 2
    },
    {
      "noiDung": "System.out.println()",
      "laDapAnDung": false,
      "thuTu": 3
    },
    {
      "noiDung": "print()",
      "laDapAnDung": false,
      "thuTu": 4
    }
  ]
}

### 6. UPDATE Question - ID Mismatch Error
PUT {{baseUrl}}/api/cauhoi/999
Content-Type: application/json

{
  "id": 8,
  "idDanhMuc": 1,
  "idLoaiCauHoi": 1,
  "noiDung": "This should fail due to ID mismatch",
  "diem": 1.0,
  "danhSachLuaChon": []
}

### 7. DELETE Question (Soft Delete)
DELETE {{baseUrl}}/api/cauhoi/8
Accept: application/json

### 8. GET Deleted Question (Should return 404)
GET {{baseUrl}}/api/cauhoi/8
Accept: application/json

### 9. CREATE Question - Missing Required Fields
POST {{baseUrl}}/api/cauhoi
Content-Type: application/json

{
  "noiDung": "Question without required fields",
  "diem": 1.0
}

### 10. GET Non-existent Question
GET {{baseUrl}}/api/cauhoi/999
Accept: application/json