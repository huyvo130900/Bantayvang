@baseUrl = https://localhost:7293

### Advanced Test Scenarios for BanTayVang API

### Scenario 1: Complete Exam Flow
# 1.1 Get available exams
GET {{baseUrl}}/api/exam/active
Accept: application/json

### 1.2 Start exam CSHARP001
POST {{baseUrl}}/api/exam/start
Content-Type: application/json

{
  "maDeThi": "CSHARP001",
  "thietBiUserAgent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
  "ip": "192.168.1.100"
}

### 1.3 Get exam questions (use baithiId from previous response)
GET {{baseUrl}}/api/exam/3/questions
Accept: application/json

### 1.4 Save multiple answers
POST {{baseUrl}}/api/exam/answer
Content-Type: application/json

{
  "idBaiThi": 3,
  "idCauHoi": 1,
  "idLuaChonDaChon": 1,
  "daLuu": true
}

###
POST {{baseUrl}}/api/exam/answer
Content-Type: application/json

{
  "idBaiThi": 3,
  "idCauHoi": 2,
  "idLuaChonDaChon": 1,
  "daLuu": true
}

### 1.5 Check progress
GET {{baseUrl}}/api/exam/3/progress
Accept: application/json

### 1.6 Log cheating warning
POST {{baseUrl}}/api/exam/warning
Content-Type: application/json

{
  "idBaiThi": 3,
  "loaiCanhBao": "TAB_SWITCH",
  "moTa": "Student switched to another tab"
}

### 1.7 Submit exam
POST {{baseUrl}}/api/exam/submit
Content-Type: application/json

{
  "idBaiThi": 3,
  "danhSachCauTraLoi": [
    {
      "idBaiThi": 3,
      "idCauHoi": 1,
      "idLuaChonDaChon": 1,
      "daLuu": true
    },
    {
      "idBaiThi": 3,
      "idCauHoi": 2,
      "idLuaChonDaChon": 1,
      "daLuu": true
    },
    {
      "idBaiThi": 3,
      "idCauHoi": 3,
      "idLuaChonDaChon": 3,
      "daLuu": true
    },
    {
      "idBaiThi": 3,
      "idCauHoi": 6,
      "idLuaChonDaChon": 2,
      "daLuu": true
    },
    {
      "idBaiThi": 3,
      "idCauHoi": 7,
      "idLuaChonDaChon": 1,
      "daLuu": true
    }
  ]
}

### Scenario 2: Question Bank Management
# 2.1 Create question with validation error (missing required field)
POST {{baseUrl}}/api/cauhoi
Content-Type: application/json

{
  "idDanhMuc": 1,
  "noiDung": "Test question without type",
  "diem": 1.0
}

### 2.2 Create question with no correct answer (should fail)
POST {{baseUrl}}/api/cauhoi
Content-Type: application/json

{
  "idDanhMuc": 1,
  "idLoaiCauHoi": 1,
  "noiDung": "Question with no correct answer",
  "diem": 1.0,
  "doKho": "Dễ",
  "khoaPhong": "CNTT",
  "danhSachLuaChon": [
    {
      "noiDung": "Wrong answer 1",
      "laDapAnDung": false,
      "thuTu": 1
    },
    {
      "noiDung": "Wrong answer 2",
      "laDapAnDung": false,
      "thuTu": 2
    }
  ]
}

### 2.3 Search questions with special characters
GET {{baseUrl}}/api/cauhoi?SearchKeyword=C%23&PageNumber=1&PageSize=5
Accept: application/json

### 2.4 Get questions with pagination
GET {{baseUrl}}/api/cauhoi?PageNumber=2&PageSize=3
Accept: application/json

### 2.5 Filter questions by multiple criteria
GET {{baseUrl}}/api/cauhoi?IdDanhMuc=1&DoKho=Dễ&KhoaPhong=CNTT&PageSize=10
Accept: application/json

### Scenario 3: Error Handling Tests
# 3.1 Try to get non-existent question
GET {{baseUrl}}/api/cauhoi/999
Accept: application/json

### 3.2 Try to start exam with invalid code
POST {{baseUrl}}/api/exam/start
Content-Type: application/json

{
  "maDeThi": "INVALID001",
  "thietBiUserAgent": "Mozilla/5.0",
  "ip": "192.168.1.100"
}

### 3.3 Try to access exam questions without permission
GET {{baseUrl}}/api/exam/999/questions
Accept: application/json

### 3.4 Try to save answer for non-existent exam
POST {{baseUrl}}/api/exam/answer
Content-Type: application/json

{
  "idBaiThi": 999,
  "idCauHoi": 1,
  "idLuaChonDaChon": 1,
  "daLuu": true
}

### Scenario 4: Bulk Operations
# 4.1 Create multiple questions rapidly
POST {{baseUrl}}/api/cauhoi
Content-Type: application/json

{
  "idDanhMuc": 4,
  "idLoaiCauHoi": 1,
  "noiDung": "What is the correct syntax for a JavaScript function?",
  "diem": 1.0,
  "doKho": "Dễ",
  "khoaPhong": "CNTT",
  "danhSachLuaChon": [
    {
      "noiDung": "function myFunction() {}",
      "laDapAnDung": true,
      "thuTu": 1
    },
    {
      "noiDung": "def myFunction() {}",
      "laDapAnDung": false,
      "thuTu": 2
    },
    {
      "noiDung": "function = myFunction() {}",
      "laDapAnDung": false,
      "thuTu": 3
    },
    {
      "noiDung": "create function myFunction() {}",
      "laDapAnDung": false,
      "thuTu": 4
    }
  ]
}

###
POST {{baseUrl}}/api/cauhoi
Content-Type: application/json

{
  "idDanhMuc": 4,
  "idLoaiCauHoi": 1,
  "noiDung": "How do you declare a variable in JavaScript?",
  "diem": 1.0,
  "doKho": "Dễ",
  "khoaPhong": "CNTT",
  "danhSachLuaChon": [
    {
      "noiDung": "var myVar;",
      "laDapAnDung": true,
      "thuTu": 1
    },
    {
      "noiDung": "variable myVar;",
      "laDapAnDung": false,
      "thuTu": 2
    },
    {
      "noiDung": "declare myVar;",
      "laDapAnDung": false,
      "thuTu": 3
    },
    {
      "noiDung": "v myVar;",
      "laDapAnDung": false,
      "thuTu": 4
    }
  ]
}

### Scenario 5: Performance Tests
# 5.1 Get large number of questions
GET {{baseUrl}}/api/cauhoi?PageSize=100
Accept: application/json

### 5.2 Get random questions multiple times
GET {{baseUrl}}/api/cauhoi/random?count=10
Accept: application/json

###
GET {{baseUrl}}/api/cauhoi/random?count=10
Accept: application/json

###
GET {{baseUrl}}/api/cauhoi/random?count=10
Accept: application/json

### Scenario 6: Edge Cases
# 6.1 Create exam with future start time
POST {{baseUrl}}/api/exam
Content-Type: application/json

{
  "maDeThi": "FUTURE001",
  "tenDeThi": "Future Exam Test",
  "thoiGianLamBai": 30,
  "thoiGianBatDau": "2025-12-31T23:59:59",
  "trangThai": "Active",
  "danhSachIdCauHoi": [1, 2, 3]
}

### 6.2 Try to start future exam (should fail)
POST {{baseUrl}}/api/exam/start
Content-Type: application/json

{
  "maDeThi": "FUTURE001",
  "thietBiUserAgent": "Mozilla/5.0",
  "ip": "192.168.1.100"
}

### 6.3 Create question with maximum length content
POST {{baseUrl}}/api/cauhoi
Content-Type: application/json

{
  "idDanhMuc": 1,
  "idLoaiCauHoi": 1,
  "noiDung": "This is a very long question content to test the maximum length validation. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum. Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque laudantium, totam rem aperiam, eaque ipsa quae ab illo inventore veritatis et quasi architecto beatae vitae dicta sunt explicabo. Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit, sed quia consequuntur magni dolores eos qui ratione voluptatem sequi nesciunt.",
  "diem": 1.0,
  "doKho": "Khó",
  "khoaPhong": "CNTT",
  "danhSachLuaChon": [
    {
      "noiDung": "Answer A",
      "laDapAnDung": true,
      "thuTu": 1
    },
    {
      "noiDung": "Answer B",
      "laDapAnDung": false,
      "thuTu": 2
    }
  ]
}